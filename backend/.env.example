# Copy to .env for local dev. On Render, set these in the dashboard (never commit .env).

# --- Required in production ---
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/nexmill_arena?retryWrites=true&w=majority
JWT_SECRET=use-openssl-rand-base64-32-or-long-random-string-here
NODE_ENV=production
PORT=5000

# Comma-separated allowed browser origins (no trailing slash)
# Include Render URL AND your custom domain after purchase, e.g.:
# CORS_ORIGINS=https://nexmill-tournament.onrender.com,https://nexmillarena.com,https://www.nexmillarena.com
CORS_ORIGINS=

# Render sets this automatically; add to CORS_ORIGINS if you use a custom domain too
RENDER_EXTERNAL_URL=

# --- Admin bootstrap (production: set ADMIN_SEED_PASSWORD before first deploy) ---
ADMIN_SEED_EMAIL=adminkush@nexmillarena.com
ADMIN_SEED_PASSWORD=

# --- Optional tuning ---
REFERRAL_COINS=100
COIN_RATE=0.2

# Debug route GET /api/debug/users (admin only) — leave unset or false in production
ENABLE_DEBUG_ROUTES=false
